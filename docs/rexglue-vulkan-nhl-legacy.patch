+  // Size-gated readback (NHL). The per-resolve readback in kFull mode does a full
+  // GPU drain (AwaitAllQueueOperationsCompletion below) so the CPU memcpy reads
+  // current pixels — but that is only needed for the small runtime-COMPOSITED
+  // textures the guest CPU re-reads/tints (player/goalie equipment). The large
+  // framebuffer-class resolves (e.g. 1280x720x4) are consumed GPU-side for present
+  // and never CPU-read, yet kFull drains the GPU on every one — the dominant CP
+  // stall on this workload (~7 of ~14.5 readbacks/frame in dense gameplay). The
+  // GPU-side resolve (compute-copy into shared_memory + MarkRangeAsResolved) has
+  // already run in render_target_cache_->Resolve() above, so skipping the CPU
+  // readback here just leaves the resolve GPU-resident — correct for every GPU
+  // consumer; only a guest-CPU-composited texture would go stale. So skip the CPU
+  // readback (and its drain) above a byte threshold while keeping the FULL
+  // same-frame readback (zero staleness) for the smaller composite targets.
+  // NHL_VK_READBACK_MAX_LEN = max bytes still read back; 0/unset = no gating (every
+  // resolve reads back, == stock kFull). The game sets a default (~3 MB) that keeps
+  // every equipment composite and skips only the framebuffers. Cached; single CP
+  // worker thread, so a plain static is safe.
+  static int64_t s_rb_max_len = -1;
+  if (s_rb_max_len < 0) {
+    const char* e = std::getenv("NHL_VK_READBACK_MAX_LEN");
+    s_rb_max_len = (e && *e) ? std::strtoll(e, nullptr, 0) : 0;
+  }
+  const bool size_skip = (s_rb_max_len > 0 && written_length > uint32_t(s_rb_max_len));
+
+  // Diagnostic (NHL_VK_RB_STATS): per-destination resolve sizes, so the size gate
+  // can be validated/tuned in any scene — "largest_kept" is the biggest dest the
+  // gate still reads back (must stay above every CPU-composited equipment target,
+  // below the framebuffers). Single CP worker thread, so plain statics are safe.
+  static int s_rb_stats = -1;
+  if (s_rb_stats < 0) s_rb_stats = std::getenv("NHL_VK_RB_STATS") ? 1 : 0;
+  if (s_rb_stats) {
+    static std::unordered_map<uint32_t, uint32_t> s_dest_max_len;  // dest addr -> max len
+    static uint64_t n = 0;
+    uint32_t& slot = s_dest_max_len[written_address];
+    slot = std::max(slot, written_length);
+    if ((++n % 4000) == 0) {
+      size_t kept = 0, skipped = 0;
+      uint32_t largest_kept = 0, smallest_skipped = UINT32_MAX;
+      for (const auto& kv : s_dest_max_len) {
+        if (s_rb_max_len > 0 && kv.second > uint32_t(s_rb_max_len)) {
+          ++skipped;
+          smallest_skipped = std::min(smallest_skipped, kv.second);
+        } else {
+          ++kept;
+          largest_kept = std::max(largest_kept, kv.second);
+        }
+      }
+      std::fprintf(stderr,
+                   "[nhl-rb] resolves=%llu dests=%zu kept=%zu skipped=%zu largest_kept=%.0fKB "
+                   "smallest_skipped=%.0fKB\n",
+                   (unsigned long long)n, s_dest_max_len.size(), kept, skipped,
+                   largest_kept / 1024.0,
+                   smallest_skipped == UINT32_MAX ? 0.0 : smallest_skipped / 1024.0);
+    }
+  }
+
+  if (size_skip) {
+    return true;  // GPU-side resolve already done; skip the CPU readback + drain
+  }
