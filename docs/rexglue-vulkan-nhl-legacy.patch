+bool VulkanTextureCache::EnsureShadowBlurScratch(uint32_t width, uint32_t height) {
+  width = std::max(width, UINT32_C(1));
+  height = std::max(height, UINT32_C(1));
+  if (shadow_blur_scratch_image_ != VK_NULL_HANDLE && shadow_blur_scratch_width_ >= width &&
+      shadow_blur_scratch_height_ >= height) {
+    return true;
+  }
+  // Grow to cover the largest shadow seen so far (avoids thrashing across sizes).
+  uint32_t new_width = std::max(width, shadow_blur_scratch_width_);
+  uint32_t new_height = std::max(height, shadow_blur_scratch_height_);
+  if (shadow_blur_scratch_image_ != VK_NULL_HANDLE) {
+    vmaDestroyImage(vma_allocator_, shadow_blur_scratch_image_, shadow_blur_scratch_allocation_);
+    shadow_blur_scratch_image_ = VK_NULL_HANDLE;
+    shadow_blur_scratch_allocation_ = VK_NULL_HANDLE;
+  }
+  VkImageCreateInfo image_create_info = {};
+  image_create_info.sType = VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO;
+  image_create_info.imageType = VK_IMAGE_TYPE_2D;
+  image_create_info.format = VK_FORMAT_R32_SFLOAT;  // Host decode of k_24_8(_FLOAT).
+  image_create_info.extent.width = new_width;
+  image_create_info.extent.height = new_height;
+  image_create_info.extent.depth = 1;
+  image_create_info.mipLevels = 1;
+  image_create_info.arrayLayers = 1;
+  image_create_info.samples = VK_SAMPLE_COUNT_1_BIT;
+  image_create_info.tiling = VK_IMAGE_TILING_OPTIMAL;
+  image_create_info.usage = VK_IMAGE_USAGE_TRANSFER_SRC_BIT | VK_IMAGE_USAGE_TRANSFER_DST_BIT;
+  image_create_info.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+  image_create_info.initialLayout = VK_IMAGE_LAYOUT_UNDEFINED;
+  VmaAllocationCreateInfo allocation_create_info = {};
+  allocation_create_info.usage = VMA_MEMORY_USAGE_AUTO_PREFER_DEVICE;
+  if (vmaCreateImage(vma_allocator_, &image_create_info, &allocation_create_info,
+                     &shadow_blur_scratch_image_, &shadow_blur_scratch_allocation_,
+                     nullptr) != VK_SUCCESS) {
+    shadow_blur_scratch_image_ = VK_NULL_HANDLE;
+    shadow_blur_scratch_allocation_ = VK_NULL_HANDLE;
+    return false;
+  }
+  shadow_blur_scratch_width_ = new_width;
+  shadow_blur_scratch_height_ = new_height;
   return true;
 }
 
+void VulkanTextureCache::SoftenDepthShadowLevel0(VulkanTexture& texture, uint32_t level0_width,
